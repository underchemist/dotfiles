# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(git aws zsh-autosuggestions direnv)

source $ZSH/oh-my-zsh.sh

# User configuration

if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi

# Aliases

# update and upgrade system packages
alias apt-up="sudo apt update && sudo apt upgrade -y && sudo apt autoremove -y"

# general path 
export PATH="$HOME/.pixi/bin:$PATH:$HOME/.local/bin:$HOME/.local/bin/nvim-linux-x86_64/bin"
export PATH="$PATH:/usr/local/go/bin:$HOME/go/bin"

{{ if .work -}}
# prescient config
export PRESCIENT_CONFIG_DIR=$HOME/.prescient
{{ end -}}

autoload bashcompinit
bashcompinit

# Node/nvim
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
